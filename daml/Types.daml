-- Types.daml
-- Shared type definitions for the digital asset transfer workflow.

module Types where

-- | Transfer request status tracking
data TransferStatus
    = Pending
    | UnderReview
    | Approved
    | Rejected Text
    deriving (Eq, Show)

-- | Check result for compliance verification
data CheckResult
    = Pass
    | Fail Text
    deriving (Eq, Show)
